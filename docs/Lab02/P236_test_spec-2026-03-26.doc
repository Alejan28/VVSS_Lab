<tr><td width="20%" valign="top"><span class="label">Importance:</span></td><td colspan="3">Medium</td></tr>
<tr><td colspan="4"></td></tr><tr><td > name of the autotest class:</td><td  colspan = "3" >Drinkshop.Domain.ProductAddTest</td></tr>
